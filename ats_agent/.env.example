# ATS Agent Configuration
# Copy this file to .env and fill in your values

# Server Configuration
AGENT_HOST=0.0.0.0
AGENT_PORT=8082
AGENT_ENV=development

# Logging
PYTHON_LOG_LEVEL=INFO

# Database Configuration (PostgreSQL)
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=ats_password
POSTGRES_DB=ats_agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Storage (set to false to use PostgreSQL, true for in-memory)
USE_INMEMORY_SAVER=true

# LLM: auto | openai | google | ollama
# auto: use OpenAI if OPENAI_API_KEY set, else Google if GOOGLE_API_KEY set, else local Ollama
LLM_PROVIDER=auto
OPENAI_API_KEY=
# Gemini (Google AI Studio): either name works
GOOGLE_API_KEY=
# GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Langfuse Observability (Optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# SSL Configuration (Optional)
AGENT_SSL_KEYFILE=
AGENT_SSL_CERTFILE=

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=["pdf", "docx", "doc", "txt"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100

# Model id (OpenAI / Google). Ollama uses OLLAMA_MODEL above.
DEFAULT_MODEL=gpt-3.5-turbo
MAX_TOKENS=4000
TEMPERATURE=0.3

# Cache Configuration
ENABLE_CACHE=true
CACHE_TTL=3600